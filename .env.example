
# Required: Your ServiceNow instance subdomain (e.g., "mycompany" for mycompany.service-now.com)
SNOW_INSTANCE=your-instance

# Required: The table to test against (e.g., "incident", "problem", "change_request")
SNOW_TABLE=incident

# Option 1: Basic Auth (username + password)
SNOW_USERNAME=your-username
SNOW_PASSWORD=your-password

# Option 2: Static bearer token (instead of username/password)
# SNOW_TOKEN=your-oauth-token

# Option 3: OAuth 2.0 refresh token (ServiceNow oauth_token.do)
# SNOW_OAUTH_CLIENT_ID=your-client-id
# SNOW_OAUTH_CLIENT_SECRET=your-client-secret
# SNOW_OAUTH_REFRESH_TOKEN=your-refresh-token
# Airtable Integration
AIRTABLE_BASE_ID=app...
AIRTABLE_TOKEN=pat...
AIRTABLE_TABLE=Tasks
